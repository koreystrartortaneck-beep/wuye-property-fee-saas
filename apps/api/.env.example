# API 环境变量示例（复制为 apps/api/.env；.env 已 gitignore，勿提交真实密钥）

# 数据库
DATABASE_URL="mysql://root:root@localhost:3306/property_fee"

# JWT（生产环境必须更换为强随机值；生产缺省或使用公开默认值将拒绝启动）
JWT_SECRET=dev-secret-change-me

# 微信能力模式：mock | real
WX_MODE=mock
WX_APPID=
WX_SECRET=

# 支付模式：mock | wxpay
PAY_MODE=mock
# PAY_MODE=mock 时必须显式设为 true；切到 wxpay 后改回 false
ALLOW_MOCK_PAYMENTS=false
WX_PAY_APP_ID=
WX_PAY_MCH_ID=
WX_PAY_API_V3_KEY=
WX_PAY_MERCHANT_SERIAL=
# PEM 可直接注入环境变量（支持把换行写成 \\n），或配置对应的本地文件路径
WX_PAY_PRIVATE_KEY=
WX_PAY_PRIVATE_KEY_PATH=
WX_PAY_PUBLIC_KEY=
WX_PAY_PUBLIC_KEY_PATH=
WX_PAY_PUBLIC_KEY_ID=
WX_PAY_NOTIFY_URL=
WX_PAY_REFUND_NOTIFY_URL=

# 灰度商户范围：预下单、回调归属、对账与告警均以此租户/小区为准（缺一不可）
WX_PAY_ALLOWED_TENANT_ID=
WX_PAY_ALLOWED_COMMUNITY_ID=

# 运营告警：HTTPS 运维 Webhook（仅接受 https://）。未配置则灰度就绪检查判为不健康。
# 告警投递前统一脱敏，绝不外发手机号/令牌/私钥/APIv3 密钥/回调原文。
OPS_ALERT_WEBHOOK=

TZ=Asia/Shanghai
PORT=3000

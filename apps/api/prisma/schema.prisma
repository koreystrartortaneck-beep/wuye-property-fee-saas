// 物业费 SaaS 数据模型（spec §5）
// 所有金额 DECIMAL(12,2)；租户域表带 tenantId 并建索引

generator client {
  provider      = "prisma-client-js"
  // 本机 + 服务器容器（Debian bookworm / OpenSSL 3）
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- 枚举（取值与 @pf/shared 一致） ----------

enum HouseType {
  RESIDENCE
  PARKING
  SHOP
}

enum RuleType {
  AREA_PRICE
  FIXED
  METER
  SHARE
  FORMULA
}

enum RulePeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum MeterType {
  WATER
  ELEC
  GAS
}

enum BillStatus {
  UNPAID
  PAID
  CANCELED
  DRAFT
  REFUNDING
  REFUNDED
}

enum BillRunStatus {
  RUNNING
  DONE
  FAILED
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
  CLOSED
  REFUNDED
  PREPAY_UNKNOWN
}

enum PaymentChannel {
  MOCK
  WXPAY
  OFFLINE
}

enum BillBatchStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
  FAILED
  CANCELED
}

enum BillSource {
  RULE
  IMPORT
}

enum PaymentConfirmationSource {
  WXPAY_NOTIFY
  WXPAY_QUERY
  OFFLINE
  MOCK
}

enum RefundType {
  FULL
}

enum RefundStatus {
  CREATED
  PROCESSING
  SUCCESS
  FAILED
  CLOSED
  ABNORMAL
}

enum RefundAttemptStatus {
  PENDING
  SUCCESS
  FAILED
  UNKNOWN
}

enum ReconciliationRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ReconciliationBillType {
  TRANSACTION
  REFUND
}

enum ReconciliationDifferenceType {
  CHANNEL_MISSING
  LOCAL_MISSING
  AMOUNT_MISMATCH
  STATUS_MISMATCH
  REFUND_MISMATCH
}

enum ReconciliationItemStatus {
  OPEN
  AUTO_RESOLVED
  MANUALLY_CLOSED
  ESCALATED
}

enum AuditActorType {
  SYSTEM
  ADMIN
  WX_USER
}

enum AuditAction {
  CREATE
  UPDATE
  PUBLISH
  CANCEL
  PAY
  REFUND
  RECONCILE
  INVOICE
  RECOVER
}

enum PaymentEventType {
  CREATED
  CHANNEL_ORDER_CREATED
  NOTIFIED
  CONFIRMED
  CLOSED
  FAILED
  REFUNDING
  REFUNDED
  RECOVERED
}

enum PaymentEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum IdempotencyStatus {
  PROCESSING
  SUCCEEDED
  FAILED
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum InvoiceTitleType {
  PERSONAL
  ENTERPRISE
}

enum InvoiceApplicationStatus {
  SUBMITTED
  PROCESSING
  ISSUED
  REJECTED
  CANCELED
  REVERSAL_REQUIRED
  REVERSED
}

enum CollectionPolicyStatus {
  OPEN
  PAUSED
}

enum BindingStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum BindingRelation {
  OWNER
  FAMILY
  TENANT
}

enum BindingSource {
  PHONE_MATCH
  APPLY
}

enum AdminRole {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
}

enum NotifyType {
  BILL_CREATED
  DUE_SOON
  OVERDUE
}

enum NotifyStatus {
  SENT
  FAILED
  SKIPPED
}

enum EntityStatus {
  ACTIVE
  DISABLED
}

// ---------- 租户与组织 ----------

model Tenant {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  contactName  String?
  contactPhone String?
  subMchId     String? // 微信支付特约商户号（子项目5）
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())

  admins           AdminUser[]
  communities      Community[]
  auditLogs         AuditLog[] @relation("AuditLogTenant")
  collectionPolicy TenantCollectionPolicy?
}

model AdminUser {
  id           String       @id @default(cuid())
  tenantId     String? // null = 平台超管
  username     String       @unique
  passwordHash String
  name         String
  role         AdminRole
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())

  // 会话加固（Task 3）
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  tokenVersion       Int       @default(0)
  passwordChangedAt  DateTime?
  mustChangePassword Boolean   @default(false)

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  publishedBills             Bill[]                      @relation("BillPublisher")
  canceledBills              Bill[]                      @relation("BillCanceler")
  createdBillBatches         BillBatch[]                 @relation("BillBatchCreator")
  publishedBillBatches       BillBatch[]                 @relation("BillBatchPublisher")
  canceledBillBatches        BillBatch[]                 @relation("BillBatchCanceler")
  offlinePayments            Payment[]                   @relation("PaymentOfflineOperator")
  requestedRefunds           Refund[]                    @relation("RefundRequester")
  createdReconciliationRuns  ReconciliationRun[]         @relation("ReconciliationRunCreator")
  handledReconciliationItems ReconciliationItem[]        @relation("ReconciliationItemHandler")
  processedInvoices          InvoiceApplication[]        @relation("InvoiceProcessor")
  changedPlatformPolicies    PlatformCollectionPolicy[]  @relation("PlatformPolicyChanger")
  changedTenantPolicies      TenantCollectionPolicy[]    @relation("TenantPolicyChanger")
  changedCommunityPolicies   CommunityCollectionPolicy[] @relation("CommunityPolicyChanger")

  @@unique([tenantId, id])
  @@index([tenantId])
}

model Community {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  address      String?
  servicePhone String? // 管家/客服电话
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())

  tenant              Tenant                     @relation(fields: [tenantId], references: [id])
  houses              House[]                    @relation("HouseCommunityTenant")
  legacyHouses        House[]                    @relation("HouseCommunityLegacy")
  feeRules            FeeRule[]                  @relation("FeeRuleCommunity")
  bills               Bill[]                     @relation("BillCommunity")
  billBatches         BillBatch[]                @relation("BillBatchCommunity")
  payments            Payment[]                  @relation("PaymentCommunity")
  refunds             Refund[]                   @relation("RefundCommunity")
  refundAttempts      RefundAttempt[]            @relation("RefundAttemptCommunity")
  reconciliationRuns  ReconciliationRun[]        @relation("ReconciliationRunCommunity")
  reconciliationItems ReconciliationItem[]       @relation("ReconciliationItemCommunity")
  auditLogs           AuditLog[]                 @relation("AuditLogCommunity")
  paymentEvents       PaymentEvent[]             @relation("PaymentEventCommunity")
  idempotencyRecords  IdempotencyRecord[]        @relation("IdempotencyCommunity")
  outboxEvents        OutboxEvent[]              @relation("OutboxCommunity")
  invoiceApplications InvoiceApplication[]       @relation("InvoiceCommunity")
  collectionPolicy    CommunityCollectionPolicy?

  @@unique([tenantId, id])
  @@index([tenantId])
}

model House {
  id          String       @id @default(cuid())
  tenantId    String
  communityId String
  type        HouseType    @default(RESIDENCE)
  building    String?
  unit        String?
  room        String?
  code        String // "8-1-2602" / "B2-118"
  displayName String // "8 栋 1 单元 2602"
  area        Decimal?     @db.Decimal(10, 2)
  ownerName   String?
  ownerPhone  String?
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())

  community       Community      @relation("HouseCommunityTenant", fields: [tenantId, communityId], references: [tenantId, id])
  legacyCommunity Community      @relation("HouseCommunityLegacy", fields: [communityId], references: [id], onDelete: Restrict)
  bindings        HouseBinding[]
  bills           Bill[]         @relation("BillHouseTenant")
  legacyBills     Bill[]         @relation("BillHouseLegacy")
  tickets         Ticket[]
  visitorPasses   VisitorPass[]
  serviceOrders   ServiceOrder[]

  @@unique([communityId, code])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([ownerPhone])
}

// ---------- 业主与绑定 ----------

model WxUser {
  id           String    @id @default(cuid())
  openid       String    @unique
  unionid      String?
  phone        String?
  nickname     String?
  tokenVersion Int       @default(0)
  phoneBoundAt DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  bindings            HouseBinding[]
  payments            Payment[]
  invoiceApplications InvoiceApplication[]
  tickets             Ticket[]

  @@index([phone])
}

model HouseBinding {
  id            String          @id @default(cuid())
  tenantId      String
  wxUserId      String
  houseId       String
  relation      BindingRelation @default(OWNER)
  status        BindingStatus   @default(PENDING)
  source         BindingSource
  applicantName  String?
  reviewedBy     String?
  reviewedAt     DateTime?
  rejectReason   String?
  phoneMatchedAt DateTime?
  revokedAt      DateTime?
  revokeReason   String?
  createdAt      DateTime        @default(now())

  wxUser WxUser @relation(fields: [wxUserId], references: [id])
  house  House  @relation(fields: [houseId], references: [id])

  @@unique([wxUserId, houseId])
  @@index([tenantId])
  @@index([houseId])
}

// ---------- 计费与账单 ----------

model FeeRule {
  id          String     @id @default(cuid())
  tenantId    String
  communityId String
  name        String
  category    String?
  houseType   HouseType  @default(RESIDENCE)
  ruleType    RuleType
  params      Json
  period      RulePeriod @default(MONTHLY)
  billDay     Int        @default(1) // 1-28
  dueDays     Int        @default(15)
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())

  community      Community   @relation("FeeRuleCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  bills          Bill[]      @relation("BillRuleTenant")
  legacyBills    Bill[]      @relation("BillRuleLegacy")
  billRuns       BillRun[]   @relation("BillRunRuleTenant")
  legacyBillRuns BillRun[]   @relation("BillRunRuleLegacy")
  billBatches    BillBatch[]

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([communityId])
}

model MeterReading {
  id        String    @id @default(cuid())
  tenantId  String
  houseId   String
  meterType MeterType
  period    String // "2026-07"
  value     Decimal   @db.Decimal(12, 2)
  prevValue Decimal?  @db.Decimal(12, 2)
  createdBy String?
  createdAt DateTime  @default(now())

  @@unique([houseId, meterType, period])
  @@index([tenantId])
}

model SharePool {
  id          String   @id @default(cuid())
  tenantId    String
  ruleId      String
  period      String
  totalAmount Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@unique([ruleId, period])
  @@index([tenantId])
}

model BillRun {
  id            String        @id @default(cuid())
  tenantId      String
  ruleId        String
  period        String
  status        BillRunStatus @default(RUNNING)
  total         Int           @default(0)
  generated     Int           @default(0)
  skipped       Int           @default(0)
  skippedDetail Json?
  startedAt     DateTime      @default(now())
  finishedAt    DateTime?

  rule        FeeRule @relation("BillRunRuleTenant", fields: [tenantId, ruleId], references: [tenantId, id])
  legacyRule  FeeRule @relation("BillRunRuleLegacy", fields: [ruleId], references: [id])
  bills       Bill[]  @relation("BillBillRunTenant")
  legacyBills Bill[]  @relation("BillBillRunLegacy")

  @@unique([ruleId, period])
  @@unique([tenantId, id])
  @@index([tenantId])
}

model Bill {
  id             String      @id @default(cuid())
  tenantId       String
  communityId    String
  houseId        String
  ruleId         String?
  billRunId      String?
  batchId        String?
  source         BillSource?
  sourceRowKey   String?
  period         String
  title          String
  snapshot       Json
  amount         Decimal     @db.Decimal(12, 2)
  status         BillStatus  @default(UNPAID)
  dueDate        DateTime
  publishedAt    DateTime?
  publishedBy    String?
  paidAt         DateTime?
  paymentId      String?
  canceledAt     DateTime?
  canceledBy     String?
  cancelReason   String?
  replacesBillId String?
  createdAt      DateTime    @default(now())

  community        Community     @relation("BillCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  house            House         @relation("BillHouseTenant", fields: [tenantId, houseId], references: [tenantId, id])
  legacyHouse      House         @relation("BillHouseLegacy", fields: [houseId], references: [id])
  rule             FeeRule?      @relation("BillRuleTenant", fields: [tenantId, ruleId], references: [tenantId, id])
  legacyRule       FeeRule?      @relation("BillRuleLegacy", fields: [ruleId], references: [id], onDelete: Restrict)
  billRun          BillRun?      @relation("BillBillRunTenant", fields: [tenantId, billRunId], references: [tenantId, id])
  legacyBillRun    BillRun?      @relation("BillBillRunLegacy", fields: [billRunId], references: [id], onDelete: Restrict)
  batch            BillBatch?    @relation(fields: [tenantId, batchId], references: [tenantId, id])
  publisher        AdminUser?    @relation("BillPublisher", fields: [tenantId, publishedBy], references: [tenantId, id])
  canceler         AdminUser?    @relation("BillCanceler", fields: [tenantId, canceledBy], references: [tenantId, id])
  replacesBill     Bill?         @relation("BillReplacement", fields: [tenantId, replacesBillId], references: [tenantId, id])
  replacementBills Bill[]        @relation("BillReplacement")
  primaryPayments  Payment[]     @relation("PaymentPrimaryBill")
  refunds          Refund[]
  paymentBills     PaymentBill[]

  @@unique([ruleId, houseId, period])
  @@unique([tenantId, id])
  @@unique([tenantId, batchId, sourceRowKey])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([tenantId, publishedBy])
  @@index([tenantId, canceledBy])
  @@index([tenantId, replacesBillId])
  @@index([batchId])
  @@index([houseId, status])
  @@index([status, dueDate])
}

// ---------- 支付与通知 ----------

model Payment {
  id                   String                     @id @default(cuid())
  tenantId             String
  wxUserId             String?
  billId               String?
  communityId          String?
  orderNo              String                     @unique
  merchantAccountId    String?
  mchid                String?
  appid                String?
  totalAmount          Decimal                    @db.Decimal(12, 2)
  channel              PaymentChannel             @default(MOCK)
  status               PaymentStatus              @default(CREATED)
  transactionId        String?                    @unique
  confirmedBy          PaymentConfirmationSource?
  confirmedAt          DateTime?
  wxpayNotifiedAt      DateTime?
  expiresAt            DateTime?
  closedAt             DateTime?
  lastSyncedAt         DateTime?
  failureCode          String?
  failureMessage       String?
  receiptNo            String?                    @unique
  receiptSnapshot      Json?
  offlineVoucherNo     String?                    @unique
  offlinePaidAt        DateTime?
  offlineOperatorId    String?
  offlinePayerSnapshot Json?
  offlineRemark        String?
  recoveredAt          DateTime?
  recoveredBy          String?
  recoveryReason       String?
  paidAt               DateTime?
  createdAt            DateTime                   @default(now())

  wxUser              WxUser?              @relation(fields: [wxUserId], references: [id], onDelete: Restrict)
  bill                Bill?                @relation("PaymentPrimaryBill", fields: [tenantId, billId], references: [tenantId, id])
  community           Community?           @relation("PaymentCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  offlineOperator     AdminUser?           @relation("PaymentOfflineOperator", fields: [tenantId, offlineOperatorId], references: [tenantId, id], onUpdate: Restrict)
  refund              Refund?
  reconciliationItems ReconciliationItem[]
  events              PaymentEvent[]
  invoiceApplication  InvoiceApplication?
  paymentBills        PaymentBill[]

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([wxUserId])
  @@index([billId])
  @@index([communityId, status])
  @@index([channel, status, createdAt])
  @@index([tenantId, offlineOperatorId])
}

model PaymentBill {
  paymentId String
  billId    String

  payment Payment @relation(fields: [paymentId], references: [id])
  bill    Bill    @relation(fields: [billId], references: [id])

  @@id([paymentId, billId])
  @@index([billId])
}

model BillBatch {
  id             String          @id @default(cuid())
  tenantId       String
  communityId    String
  batchNo        String
  period         String
  title          String?
  source         BillSource
  ruleId         String?
  importFileName String?
  importFileHash String?
  status         BillBatchStatus @default(DRAFT)
  totalRows      Int             @default(0)
  validRows      Int             @default(0)
  invalidRows    Int             @default(0)
  totalAmount    Decimal         @default(0) @db.Decimal(12, 2)
  createdBy      String?
  publishedAt    DateTime?
  publishedBy    String?
  canceledAt     DateTime?
  canceledBy     String?
  cancelReason   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt

  community Community  @relation("BillBatchCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  rule      FeeRule?   @relation(fields: [tenantId, ruleId], references: [tenantId, id], onUpdate: Restrict)
  creator   AdminUser? @relation("BillBatchCreator", fields: [tenantId, createdBy], references: [tenantId, id])
  publisher AdminUser? @relation("BillBatchPublisher", fields: [tenantId, publishedBy], references: [tenantId, id])
  canceler  AdminUser? @relation("BillBatchCanceler", fields: [tenantId, canceledBy], references: [tenantId, id])
  bills     Bill[]

  @@unique([tenantId, batchNo])
  @@unique([tenantId, id])
  @@unique([tenantId, communityId, importFileHash])
  @@index([tenantId])
  @@index([communityId, status])
  @@index([tenantId, ruleId])
  @@index([tenantId, createdBy])
  @@index([tenantId, publishedBy])
  @@index([tenantId, canceledBy])
  @@index([period])
}

model Refund {
  id                String         @id @default(cuid())
  tenantId          String
  communityId       String?
  paymentId         String         @unique
  paymentOrderNo    String
  billId            String?
  merchantAccountId String
  mchid             String
  appid             String
  refundNo          String         @unique
  providerRefundId  String?        @unique
  type              RefundType
  originalAmount    Decimal        @db.Decimal(12, 2)
  refundAmount      Decimal        @db.Decimal(12, 2)
  currency          String         @default("CNY") @db.Char(3)
  reason            String
  channel           PaymentChannel
  status            RefundStatus   @default(CREATED)
  requestedBy       String?
  requestedAt       DateTime       @default(now())
  processingAt      DateTime?
  refundedAt        DateTime?
  notifyReceivedAt  DateTime?
  lastQueriedAt     DateTime?
  failedAt          DateTime?
  closedAt          DateTime?
  failureCode       String?
  failureMessage    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt

  payment             Payment              @relation(fields: [tenantId, paymentId], references: [tenantId, id])
  bill                Bill?                @relation(fields: [tenantId, billId], references: [tenantId, id])
  community           Community?           @relation("RefundCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  requester           AdminUser?           @relation("RefundRequester", fields: [tenantId, requestedBy], references: [tenantId, id])
  attempts            RefundAttempt[]
  reconciliationItems ReconciliationItem[]
  events              PaymentEvent[]

  @@unique([tenantId, id])
  @@unique([tenantId, paymentId])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([tenantId, requestedBy])
  @@index([paymentOrderNo])
  @@index([billId])
}

model RefundAttempt {
  id              String              @id @default(cuid())
  tenantId        String
  communityId     String?
  refundId        String
  attemptNo       Int
  status          RefundAttemptStatus @default(PENDING)
  requestHash     String
  requestSummary  Json?
  responseSummary Json?
  errorCode       String?
  errorMessage    String?
  attemptedAt     DateTime            @default(now())
  finishedAt      DateTime?

  refund    Refund     @relation(fields: [tenantId, refundId], references: [tenantId, id])
  community Community? @relation("RefundAttemptCommunity", fields: [tenantId, communityId], references: [tenantId, id])

  @@unique([tenantId, refundId, attemptNo])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([status, attemptedAt])
}

model ReconciliationRun {
  id                    String                  @id @default(cuid())
  tenantId              String
  communityId           String?
  runNo                 String                  @unique
  merchantAccountId     String
  mchid                 String
  appid                 String
  channel               PaymentChannel
  businessDate          DateTime                @db.Date
  billType              ReconciliationBillType
  channelFileHash       String?
  channelRecordCount    Int                     @default(0)
  channelAmount         Decimal                 @default(0) @db.Decimal(12, 2)
  localRecordCount      Int                     @default(0)
  localAmount           Decimal                 @default(0) @db.Decimal(12, 2)
  matchedRecordCount    Int                     @default(0)
  differenceRecordCount Int                     @default(0)
  differenceAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  status                ReconciliationRunStatus @default(RUNNING)
  leaseOwner            String?
  leaseExpiresAt        DateTime?
  errorMessage          String?
  createdBy             String?
  startedAt             DateTime                @default(now())
  finishedAt            DateTime?
  createdAt             DateTime                @default(now())

  community Community?           @relation("ReconciliationRunCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  creator   AdminUser?           @relation("ReconciliationRunCreator", fields: [tenantId, createdBy], references: [tenantId, id])
  items     ReconciliationItem[]

  @@unique([tenantId, id])
  @@unique([merchantAccountId, businessDate, billType])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([status, leaseExpiresAt])
  @@index([status, startedAt])
  @@index([tenantId, createdBy])
}

model ReconciliationItem {
  id                   String                       @id @default(cuid())
  tenantId             String
  communityId          String?
  runId                String
  paymentId            String?
  refundId             String?
  orderNo              String
  differenceType       ReconciliationDifferenceType
  status               ReconciliationItemStatus     @default(OPEN)
  localAmount          Decimal?                     @db.Decimal(12, 2)
  channelAmount        Decimal?                     @db.Decimal(12, 2)
  differenceAmount     Decimal?                     @db.Decimal(12, 2)
  localStatus          String?
  channelStatus        String?
  channelTransactionId String?
  detailSummary        Json?
  handledBy            String?
  handledAt            DateTime?
  handlingRemark       String?
  createdAt            DateTime                     @default(now())

  run       ReconciliationRun @relation(fields: [tenantId, runId], references: [tenantId, id])
  payment   Payment?          @relation(fields: [tenantId, paymentId], references: [tenantId, id])
  refund    Refund?           @relation(fields: [tenantId, refundId], references: [tenantId, id])
  community Community?        @relation("ReconciliationItemCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  handler   AdminUser?        @relation("ReconciliationItemHandler", fields: [tenantId, handledBy], references: [tenantId, id])

  @@unique([runId, orderNo, differenceType])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([paymentId])
  @@index([refundId])
  @@index([status])
  @@index([tenantId, handledBy])
}

model AuditLog {
  id            String         @id @default(cuid())
  tenantId      String
  communityId   String?
  actorType     AuditActorType @default(SYSTEM)
  actorId       String?
  action        AuditAction
  resourceType  String
  resourceId    String
  reason        String?
  requestId     String?
  ip            String?
  userAgent     String?
  beforeSummary Json?
  afterSummary  Json?
  createdAt     DateTime       @default(now())

  tenant    Tenant     @relation("AuditLogTenant", fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  community Community? @relation("AuditLogCommunity", fields: [tenantId, communityId], references: [tenantId, id], onUpdate: Restrict, map: "AuditLog_tenantId_communityId_restrict_fkey")

  @@index([tenantId, createdAt])
  @@index([tenantId, communityId, createdAt])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@index([actorId, createdAt])
}

model PaymentEvent {
  id             String             @id @default(cuid())
  tenantId       String
  communityId    String?
  paymentId      String?
  refundId       String?
  eventKey       String
  type           PaymentEventType
  status         PaymentEventStatus @default(PENDING)
  source         String?
  payloadHash    String?
  summary        Json?
  attempts       Int                @default(0)
  availableAt    DateTime           @default(now())
  claimOwner     String?
  claimExpiresAt DateTime?
  processedAt    DateTime?
  lastError      String?
  occurredAt     DateTime           @default(now())
  createdAt      DateTime           @default(now())

  payment   Payment?   @relation(fields: [tenantId, paymentId], references: [tenantId, id], onUpdate: Restrict)
  refund    Refund?    @relation(fields: [tenantId, refundId], references: [tenantId, id], onUpdate: Restrict)
  community Community? @relation("PaymentEventCommunity", fields: [tenantId, communityId], references: [tenantId, id])

  @@unique([tenantId, eventKey])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([paymentId, occurredAt])
  @@index([refundId, occurredAt])
  @@index([status, availableAt])
  @@index([type, occurredAt])
}

model IdempotencyRecord {
  id             String            @id @default(cuid())
  tenantId       String
  communityId    String?
  actorKey       String
  action         String
  requestId      String
  status         IdempotencyStatus @default(PROCESSING)
  requestHash    String
  responseCode   Int?
  responseBody   Json?
  errorCode      String?
  errorMessage   String?
  attempts       Int               @default(0)
  claimOwner     String?
  claimExpiresAt DateTime?
  nextRetryAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt

  community Community? @relation("IdempotencyCommunity", fields: [tenantId, communityId], references: [tenantId, id])

  @@unique([tenantId, actorKey, action, requestId])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([status, claimExpiresAt])
  @@index([status, nextRetryAt])
  @@index([expiresAt])
}

model OutboxEvent {
  id             String            @id @default(cuid())
  tenantId       String
  communityId    String?
  aggregateType  String
  aggregateId    String
  eventType      String
  dedupKey       String
  payload        Json
  status         OutboxEventStatus @default(PENDING)
  attempts       Int               @default(0)
  availableAt    DateTime          @default(now())
  claimOwner     String?
  claimExpiresAt DateTime?
  lastAttemptAt  DateTime?
  publishedAt    DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt

  community Community? @relation("OutboxCommunity", fields: [tenantId, communityId], references: [tenantId, id])

  @@unique([tenantId, dedupKey])
  @@index([tenantId, status, availableAt])
  @@index([tenantId, availableAt, createdAt, id])
  @@index([status, claimExpiresAt])
  @@index([tenantId, communityId])
  @@index([aggregateType, aggregateId])
}

model InvoiceApplication {
  id                 String                   @id @default(cuid())
  tenantId           String
  communityId        String
  paymentId          String
  wxUserId           String
  applicationNo      String                   @unique
  titleType          InvoiceTitleType
  title              String
  taxNo              String?
  deliveryMethod     String
  email              String?
  amount             Decimal                  @db.Decimal(12, 2)
  status             InvoiceApplicationStatus @default(SUBMITTED)
  invoiceNo          String?                  @unique
  invoiceUrl         String?
  processedBy        String?
  appliedAt          DateTime                 @default(now())
  issuedAt           DateTime?
  rejectedAt         DateTime?
  rejectReason       String?
  reversalRequiredAt DateTime?
  reversedAt         DateTime?
  reversalRemark     String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @default(now()) @updatedAt

  payment   Payment    @relation(fields: [tenantId, paymentId], references: [tenantId, id])
  community Community  @relation("InvoiceCommunity", fields: [tenantId, communityId], references: [tenantId, id])
  wxUser    WxUser     @relation(fields: [wxUserId], references: [id])
  processor AdminUser? @relation("InvoiceProcessor", fields: [tenantId, processedBy], references: [tenantId, id])

  @@unique([tenantId, paymentId])
  @@index([tenantId])
  @@index([tenantId, communityId])
  @@index([wxUserId])
  @@index([status, appliedAt])
  @@index([tenantId, processedBy])
}

model PlatformCollectionPolicy {
  id        String                 @id @default(cuid())
  code      String                 @unique
  name      String
  status    CollectionPolicyStatus @default(OPEN)
  changedBy String?
  reason    String?
  changedAt DateTime               @default(now())
  resumeAt  DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt

  changer        AdminUser?               @relation("PlatformPolicyChanger", fields: [changedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  tenantPolicies TenantCollectionPolicy[]

  @@index([changedBy])
  @@index([status, resumeAt])
}

model TenantCollectionPolicy {
  id               String                 @id @default(cuid())
  tenantId         String                 @unique
  platformPolicyId String?
  status           CollectionPolicyStatus @default(OPEN)
  changedBy        String?
  reason           String?
  changedAt        DateTime               @default(now())
  resumeAt         DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @default(now()) @updatedAt

  tenant            Tenant                      @relation(fields: [tenantId], references: [id])
  platformPolicy    PlatformCollectionPolicy?   @relation(fields: [platformPolicyId], references: [id], onDelete: SetNull)
  changer           AdminUser?                  @relation("TenantPolicyChanger", fields: [tenantId, changedBy], references: [tenantId, id], onUpdate: Restrict)
  communityPolicies CommunityCollectionPolicy[]

  @@unique([tenantId, id])
  @@index([platformPolicyId])
  @@index([tenantId, status, resumeAt])
  @@index([tenantId, changedBy])
}

model CommunityCollectionPolicy {
  id             String                 @id @default(cuid())
  tenantId       String
  communityId    String
  tenantPolicyId String?
  status         CollectionPolicyStatus @default(OPEN)
  changedBy      String?
  reason         String?
  changedAt      DateTime               @default(now())
  resumeAt       DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt

  community    Community               @relation(fields: [tenantId, communityId], references: [tenantId, id])
  tenantPolicy TenantCollectionPolicy? @relation(fields: [tenantId, tenantPolicyId], references: [tenantId, id])
  changer      AdminUser?              @relation("CommunityPolicyChanger", fields: [tenantId, changedBy], references: [tenantId, id], onUpdate: Restrict)

  @@unique([tenantId, communityId])
  @@index([tenantId, status, resumeAt])
  @@index([tenantPolicyId])
  @@index([tenantId, changedBy])
}

model NotifyLog {
  id       String       @id @default(cuid())
  tenantId String
  wxUserId String?
  billId   String?
  type     NotifyType
  channel  String       @default("MOCK") // WX_SUBSCRIBE | MOCK
  status   NotifyStatus
  error    String?
  sentAt   DateTime     @default(now())

  @@index([tenantId])
  @@index([billId, type, status])
}

// ---------- 二期：工单 / 访客 / 公告 ----------

enum TicketType {
  REPAIR
  COMPLAINT
  SUGGESTION
}

enum TicketStatus {
  PENDING
  PROCESSING
  DONE
  CLOSED
}

enum PassStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELED
}

enum AnnouncementStatus {
  PUBLISHED
  REVOKED
}

model Ticket {
  id            String       @id @default(cuid())
  tenantId      String
  communityId   String
  houseId       String
  wxUserId      String
  type          TicketType
  content       String       @db.Text
  images        Json // 图片 URL 数组
  status        TicketStatus @default(PENDING)
  assigneeName  String?
  replyContent  String?      @db.Text
  processedAt   DateTime?
  doneAt        DateTime?
  rating        Int? // 完成后业主评分 1-5
  ratingComment String?
  createdAt     DateTime     @default(now())

  house  House  @relation(fields: [houseId], references: [id])
  wxUser WxUser @relation(fields: [wxUserId], references: [id])

  @@index([tenantId])
  @@index([houseId])
  @@index([status])
}

model VisitorPass {
  id           String     @id @default(cuid())
  tenantId     String
  communityId  String
  houseId      String
  wxUserId     String
  visitorName  String
  visitorPhone String?
  plateNo      String?
  visitDate    DateTime // 到访日（当天有效）
  code         String // 6 位数字通行码
  status       PassStatus @default(ACTIVE)
  usedAt       DateTime?
  createdAt    DateTime   @default(now())

  house House @relation(fields: [houseId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([visitDate])
}

model Announcement {
  id          String             @id @default(cuid())
  tenantId    String
  communityId String? // null = 公司全部小区
  title       String
  content     String             @db.Text
  pinned      Boolean            @default(false)
  status      AnnouncementStatus @default(PUBLISHED)
  createdBy   String?
  publishedAt DateTime           @default(now())

  @@index([tenantId])
}

// ---------- 三期：工作照片墙 / 生活服务 / 卡券 ----------

enum WorkCategory {
  INSPECTION // 日常巡检
  CLEANING // 保洁
  GREENING // 绿化
  SECURITY // 安保
  REPAIR // 维修
  OTHER // 其他
}

enum ServiceOrderStatus {
  PENDING // 待接单
  ACCEPTED // 已接单
  DONE // 已完成
  CANCELED // 已取消
}

enum CouponType {
  DISCOUNT // 满减/抵扣（可抵物业费）
  SERVICE // 服务券（免上门费等）
  GIFT // 礼品券
}

enum UserCouponStatus {
  UNUSED
  USED
  EXPIRED
}

model WorkLog {
  id          String       @id @default(cuid())
  tenantId    String
  communityId String
  category    WorkCategory @default(OTHER)
  title       String?
  description String?      @db.Text
  images      Json // 图片 URL 数组
  staffName   String?
  createdBy   String?
  createdAt   DateTime     @default(now())

  @@index([tenantId])
  @@index([communityId])
}

model ServiceItem {
  id          String   @id @default(cuid())
  tenantId    String
  communityId String? // null = 公司全部小区
  name        String
  category    String?
  price       Decimal  @db.Decimal(10, 2)
  unit        String   @default("元/次")
  description String?  @db.Text
  coverImage  String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  orders ServiceOrder[]

  @@index([tenantId])
}

model ServiceOrder {
  id            String             @id @default(cuid())
  tenantId      String
  communityId   String
  houseId       String
  wxUserId      String
  serviceItemId String
  serviceName   String // 快照
  price         Decimal            @db.Decimal(10, 2) // 快照
  unit          String // 快照
  contactName   String
  contactPhone  String
  expectDate    DateTime
  remark        String?
  status        ServiceOrderStatus @default(PENDING)
  acceptedAt    DateTime?
  doneAt        DateTime?
  createdAt     DateTime           @default(now())

  house       House       @relation(fields: [houseId], references: [id])
  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id])

  @@index([tenantId])
  @@index([houseId])
  @@index([status])
}

model Coupon {
  id           String     @id @default(cuid())
  tenantId     String
  communityId  String? // null = 公司全部小区
  name         String
  type         CouponType @default(DISCOUNT)
  faceValue    Decimal?   @db.Decimal(10, 2) // 抵扣/面额
  threshold    Decimal?   @db.Decimal(10, 2) // 满减门槛
  description  String?    @db.Text
  totalQty     Int // 发行总量
  claimedQty   Int        @default(0)
  perUserLimit Int        @default(1)
  validFrom    DateTime
  validTo      DateTime
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())

  userCoupons UserCoupon[]

  @@index([tenantId])
}

model UserCoupon {
  id        String           @id @default(cuid())
  tenantId  String
  couponId  String
  wxUserId  String
  code      String // 核销码
  status    UserCouponStatus @default(UNUSED)
  claimedAt DateTime         @default(now())
  usedAt    DateTime?

  coupon Coupon @relation(fields: [couponId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([wxUserId])
}

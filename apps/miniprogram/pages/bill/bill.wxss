.bill-page {
  padding-bottom: 48rpx;
}

.summary-card {
  margin-top: 34rpx;
  padding: 42rpx 36rpx;
  border-radius: 52rpx;
  color: #fff;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  background: radial-gradient(circle at 90% 0%, rgba(201, 166, 107, 0.72), transparent 30%), linear-gradient(145deg, #102033, #223f59 64%, #5f7f86);
  box-shadow: 0 32rpx 78rpx rgba(16, 32, 51, 0.24);
}

.summary-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.summary-amount {
  margin-top: 12rpx;
  font-size: 62rpx;
  font-weight: 900;
}

.summary-btn {
  height: 76rpx;
  padding: 0 28rpx;
  font-size: 25rpx;
}

.tabs {
  margin-top: 28rpx;
  padding: 10rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.tab-item {
  height: 70rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #82786c;
  font-size: 26rpx;
  font-weight: 700;
}

.tab-active {
  color: #102033;
  background: linear-gradient(145deg, #fff1c8, #ead0a0);
}

.bill-stack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.bill-item {
  padding: 30rpx 22rpx 30rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.bill-paid {
  opacity: 0.72;
}

.bill-info {
  flex: 1;
  min-width: 0;
}

.bill-dot {
  width: 22rpx;
  height: 88rpx;
  border-radius: 999rpx;
}

.sapphire { background: linear-gradient(180deg, #395875, #102033); }
.emerald { background: linear-gradient(180deg, #6f9795, #315f63); }
.amber { background: linear-gradient(180deg, #ddbd76, #9b743a); }

.bill-name {
  font-size: 30rpx;
  font-weight: 900;
}

.bill-period {
  margin-top: 10rpx;
  color: #82786c;
  font-size: 24rpx;
}

.bill-side {
  text-align: right;
}

.bill-money {
  font-size: 32rpx;
  font-weight: 900;
}

.status {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #9b743a;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(201, 166, 107, 0.16);
}

.status-paid {
  color: #5f7f86;
  background: rgba(95, 127, 134, 0.14);
}

/* 勾选态（动态化新增） */
.bill-selected {
  border: 2rpx solid #c9a66b;
  box-shadow: 0 18rpx 44rpx rgba(155, 116, 58, 0.22);
}

/* 逾期状态 */
.status-overdue {
  color: #c45656;
  background: rgba(196, 86, 86, 0.12);
}

/* 待缴账单的勾选圈（catchtap，选择动作与整卡详情分离） */
.check-circle {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(155, 116, 58, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fffaf2;
  background: transparent;
  transition: all 0.15s ease;
}

.check-on {
  border-color: #c9a66b;
  background: linear-gradient(145deg, #e3bd7d, #9b743a);
  box-shadow: 0 6rpx 16rpx rgba(155, 116, 58, 0.35);
}

/* 右侧详情箭头（视觉引导：整卡可点） */
.chevron {
  flex-shrink: 0;
  color: rgba(130, 120, 108, 0.55);
  font-size: 36rpx;
  font-weight: 300;
  padding-left: 4rpx;
}

/* 科目筛选条（分组功能新增） */
.filter-bar {
  margin-top: 22rpx;
  white-space: nowrap;
}

.filter-inner {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 4rpx;
}

.filter-chip {
  display: inline-flex;
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #82786c;
  background: rgba(255, 250, 242, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
}

.chip-active {
  color: #102033;
  background: linear-gradient(145deg, #fff1c8, #ead0a0);
  border-color: rgba(201, 166, 107, 0.5);
}

/* 账期分组头 */
.group-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 10rpx 12rpx 0;
  margin-top: 8rpx;
}

.group-period {
  font-size: 28rpx;
  font-weight: 900;
  color: #102033;
  letter-spacing: 1rpx;
}

.group-subtotal {
  font-size: 22rpx;
  color: #8a7f73;
}

.list-end {
  text-align: center;
  color: #b3aa9d;
  font-size: 22rpx;
  padding: 16rpx 0 8rpx;
}

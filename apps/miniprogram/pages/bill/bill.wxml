<view class="page bill-page">
  <view class="nav-title">账单中心</view>
  <view class="nav-subtitle">{{house ? house.communityName + ' ' + house.displayName : '清晰记录每一笔物业费用'}}</view>

  <view class="summary-card">
    <view>
      <view class="summary-label">{{selectedIds.length > 0 ? '已选 ' + selectedIds.length + ' 笔' : '待缴合计（' + unpaidCount + ' 笔）'}}</view>
      <view class="summary-amount amount">¥ {{selectedIds.length > 0 ? selectedTotal : unpaidTotal}}</view>
    </view>
    <button class="gold-button summary-btn" bindtap="goPay">{{selectedIds.length > 0 ? '缴纳所选' : '全部缴纳'}}</button>
  </view>

  <view class="tabs card">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view class="tab-item {{activeTab === index ? 'tab-active' : ''}}" data-index="{{index}}" bindtap="setTab">{{item}}</view>
    </block>
  </view>

  <!-- 费用科目筛选条 -->
  <scroll-view wx:if="{{filters.length > 2}}" class="filter-bar" scroll-x enable-flick="{{true}}">
    <view class="filter-inner">
      <view
        wx:for="{{filters}}"
        wx:key="ruleId"
        class="filter-chip {{activeRuleId === item.ruleId ? 'chip-active' : ''}}"
        data-id="{{item.ruleId}}"
        bindtap="setFilter"
      >{{item.name}}</view>
    </view>
  </scroll-view>

  <!-- 按账期分组 -->
  <view class="bill-stack">
    <block wx:for="{{groups}}" wx:key="period" wx:for-item="group">
      <view class="group-head">
        <view class="group-period">{{group.period}}</view>
        <view class="group-subtotal">{{group.count}} 笔 · ¥{{group.subtotal}}</view>
      </view>
      <block wx:for="{{group.items}}" wx:key="id">
        <view class="bill-item card {{item.paid ? 'bill-paid' : ''}} {{selectedIds.indexOf(item.id) >= 0 ? 'bill-selected' : ''}}"
              data-id="{{item.id}}" bindtap="goDetailById">
          <view wx:if="{{!item.paid}}"
                class="check-circle {{selectedIds.indexOf(item.id) >= 0 ? 'check-on' : ''}}"
                data-id="{{item.id}}" catchtap="toggleSelect">
            <text wx:if="{{selectedIds.indexOf(item.id) >= 0}}">✓</text>
          </view>
          <view wx:else class="bill-dot {{item.theme}}"></view>

          <view class="bill-info">
            <view class="bill-name">{{item.title}}</view>
            <view class="bill-period">{{item.subline}}</view>
          </view>

          <view class="bill-side">
            <view class="bill-money amount">¥{{item.amount}}</view>
            <view class="status {{item.paid ? 'status-paid' : ''}} {{item.overdue ? 'status-overdue' : ''}}">{{item.status}}</view>
          </view>
          <view class="chevron">›</view>
        </view>
      </block>
    </block>

    <view wx:if="{{bills.length === 0}}" class="bill-item card">
      <view class="bill-info">
        <view class="bill-name">暂无账单</view>
        <view class="bill-period">{{house ? '当前分类下没有账单' : '请先在首页绑定房屋'}}</view>
      </view>
    </view>

    <view wx:if="{{bills.length > 0 && bills.length >= total}}" class="list-end">已显示全部 {{total}} 笔</view>
  </view>
</view>

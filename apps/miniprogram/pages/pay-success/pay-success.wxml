<view class="page success-page">
  <view class="success-card">
    <view class="success-ring">
      <view class="success-check">✓</view>
    </view>
    <view class="success-title">缴费成功</view>
    <view class="success-desc">您的物业费用已实时入账</view>
    <view class="success-amount amount">¥ {{amount}}</view>
  </view>

  <view class="receipt-card card">
    <view class="receipt-title">电子凭证</view>
    <view class="receipt-row">
      <text>房屋</text>
      <text>{{house}}</text>
    </view>
    <view class="receipt-row">
      <text>订单号</text>
      <text>{{orderNo}}</text>
    </view>
    <view class="receipt-row">
      <text>支付时间</text>
      <text>{{payTime}}</text>
    </view>
    <view class="receipt-row">
      <text>支付方式</text>
      <text>微信支付</text>
    </view>
  </view>

  <view class="action-row">
    <button class="gold-button ghost-btn" bindtap="viewReceipt">电子收据</button>
    <button class="dark-button action-btn" bindtap="backHome">返回首页</button>
  </view>
</view>

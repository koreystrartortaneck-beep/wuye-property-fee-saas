.page.cpn-page {
  padding-top: 24rpx;
}

.cpn-tabs {
  display: flex;
  padding: 10rpx;
  margin-bottom: 22rpx;
}

.cpn-tab {
  flex: 1;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #7c7288;
}

.tab-on {
  color: #251c38;
  background: linear-gradient(145deg, #fff1c8, #ead0a0);
}

.cpn-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* 券卡：左侧金色面额区 + 中部信息 + 右侧动作 */
.ticket {
  display: flex;
  align-items: stretch;
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(253, 251, 247, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 20rpx 48rpx rgba(70, 52, 29, 0.08);
}

.ticket-dim {
  opacity: 0.55;
}

.ticket-left {
  width: 210rpx;
  flex-shrink: 0;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: radial-gradient(circle at 80% 0%, rgba(232, 207, 160, 0.4), transparent 40%), linear-gradient(150deg, #2b2145, #3b2b57);
  position: relative;
}

.ticket-left::after {
  content: "";
  position: absolute;
  right: -12rpx;
  top: 0;
  bottom: 0;
  width: 24rpx;
  background-image: radial-gradient(circle at 0 12rpx, transparent 12rpx, rgba(253, 251, 247, 0.92) 12rpx);
  background-size: 24rpx 32rpx;
  background-repeat: repeat-y;
}

.ticket-value {
  font-size: 60rpx;
  font-weight: 900;
  color: #e8cfa0;
  font-family: DIN Alternate, sans-serif;
  line-height: 1;
}

.tv-cur {
  font-size: 30rpx;
}

.ticket-sub {
  margin-top: 10rpx;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.75);
}

.ticket-mid {
  flex: 1;
  min-width: 0;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ticket-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #251c38;
}

.ticket-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c7288;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.ticket-code {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9b743a;
  font-weight: 600;
}

.ticket-valid {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a79eb5;
}

.ticket-right {
  flex-shrink: 0;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.ticket-btn {
  height: 60rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
}

.ticket-got {
  font-size: 23rpx;
  color: #3f7d5d;
  font-weight: 700;
}

.ticket-out {
  font-size: 23rpx;
  color: #a79eb5;
}

.ticket-status {
  font-size: 24rpx;
  font-weight: 800;
}

.ts-UNUSED { color: #9b743a; }
.ts-USED { color: #9a92a3; }
.ts-EXPIRED { color: #b8862f; }

.cpn-empty {
  padding: 60rpx 40rpx;
  text-align: center;
}

.ce-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #251c38;
}

.ce-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8b8199;
  line-height: 1.5;
}

<view class="page index-page">
  <view class="top-line">
    <view>
      <view class="nav-title">{{communityName}}</view>
      <view class="nav-subtitle">雅致生活 · 从容缴费</view>
    </view>
    <view class="profile-orb">{{avatarText}}</view>
  </view>

  <view class="hero-card">
    <view class="hero-kicker">PROPERTY SERVICE</view>
    <view class="hero-title">优雅缴费\n从容生活</view>
    <view class="house-chip">
      <view class="chip-dot"></view>
      <text>{{currentHouse}}</text>
    </view>
    <view class="amount-panel">
      <view class="panel-label">本期应缴</view>
      <view class="amount-row">
        <view class="hero-amount amount">¥ {{totalAmount}}</view>
        <button class="gold-button pay-btn" bindtap="goPay">立即缴纳</button>
      </view>
    </view>
  </view>

  <view class="quick-grid">
    <block wx:for="{{quickActions}}" wx:key="title">
      <view class="quick-card {{item.active ? 'quick-active' : ''}}" data-index="{{index}}" bindtap="handleQuickTap">
        <view class="quick-icon">{{item.icon}}</view>
        <view class="quick-title">{{item.title}}</view>
        <view class="quick-desc">{{item.desc}}</view>
      </view>
    </block>
  </view>

  <view class="section-head">
    <view>
      <view class="section-kicker">费用组成</view>
      <view class="section-title">本月账单</view>
    </view>
    <view class="section-more" bindtap="goBill">查看全部</view>
  </view>

  <view class="bill-list">
    <block wx:for="{{bills}}" wx:key="title">
      <view class="bill-card card">
        <view class="bill-left">
          <view class="bill-icon {{item.theme}}">{{item.icon}}</view>
          <view>
            <view class="bill-title">{{item.title}}</view>
            <view class="bill-desc">{{item.desc}}</view>
          </view>
        </view>
        <view class="bill-amount amount">¥{{item.amount}}</view>
      </view>
    </block>
  </view>

  <view class="service-card card">
    <view>
      <view class="service-kicker">尊享服务</view>
      <view class="service-title">开通自动提醒，避免逾期</view>
      <view class="service-desc">每月账单生成后自动推送微信提醒</view>
    </view>
    <button class="mini-dark">开启</button>
  </view>
</view>

<view class="page index-page has-navbar">
  <view style="height: {{nav.spacerPx}}px"></view>
  <view class="nav-row" style="height: {{nav.rowPx}}px">
    <view class="nav-row-title">{{currentHouse ? currentHouse.communityName : '物业缴费'}}</view>
  </view>
  <view class="nav-sub-row">雅致生活 · 从容缴费</view>

  <!-- 首屏加载态 -->
  <view wx:if="{{!ready}}" class="hero-card">
    <view class="hero-kicker">PROPERTY SERVICE</view>
    <view class="hero-title">加载中…</view>
    <view class="amount-panel">
      <view class="panel-label">正在获取您的房屋与账单</view>
    </view>
  </view>

  <!-- 未绑定房屋引导 -->
  <view wx:if="{{ready && noHouse}}" class="hero-card">
    <view class="hero-kicker">PROPERTY SERVICE</view>
    <view class="hero-title">绑定房屋\n开启从容缴费</view>
    <view class="amount-panel">
      <view class="panel-label">首次使用请先绑定您的房屋</view>
      <view class="amount-row">
        <view class="hero-amount amount"> </view>
        <button class="gold-button pay-btn" bindtap="goBind">立即绑定</button>
      </view>
    </view>
  </view>

  <!-- 正常态 -->
  <block wx:if="{{ready && !noHouse}}">
    <!-- ① 缴费中心：账单的唯一入口 -->
    <view class="hero-card">
      <view class="hero-kicker">PROPERTY SERVICE</view>
      <view class="hero-title">{{paidUp ? '本期缴清\n生活从容' : '优雅缴费\n从容生活'}}</view>
      <view class="house-chip" bindtap="switchHouse">
        <view class="chip-dot"></view>
        <text>{{currentHouse.displayName}}{{houses.length > 1 ? ' ⇄' : ''}}</text>
      </view>
      <view class="amount-panel">
        <view class="panel-label">{{paidUp ? '本期费用已全部缴清' : '待缴合计（' + unpaidCount + ' 笔）'}}</view>
        <view class="amount-row">
          <view class="hero-amount amount">{{paidUp ? '✓' : '¥ ' + unpaidTotal}}</view>
          <button class="gold-button pay-btn" bindtap="heroAction">{{paidUp ? '查看账单' : '立即缴纳'}}</button>
        </view>
      </view>
    </view>

    <!-- ② 快捷服务 -->
    <view class="quick-grid">
      <block wx:for="{{quickActions}}" wx:key="title">
        <view class="quick-card {{item.active ? 'quick-active' : ''}}" data-index="{{index}}" bindtap="handleQuickTap">
          <view class="quick-icon">{{item.icon}}</view>
          <view class="quick-title">{{item.title}}</view>
          <view class="quick-desc">{{item.desc}}</view>
        </view>
      </block>
    </view>

    <!-- ③ 社区动态 -->
    <view class="section-head">
      <view>
        <view class="section-kicker">{{currentHouse.communityName}}</view>
        <view class="section-title">社区动态</view>
      </view>
      <view class="section-more" bindtap="goAnnList">查看全部</view>
    </view>

    <view class="home-ann-list">
      <block wx:for="{{annList}}" wx:key="id">
        <view class="home-ann-item card" data-id="{{item.id}}" bindtap="goAnnDetail">
          <view class="ha-title-row">
            <text wx:if="{{item.pinned}}" class="ha-pin">置顶</text>
            <text class="ha-title">{{item.title}}</text>
            <text class="ha-date">{{item.date}}</text>
          </view>
          <view class="ha-preview">{{item.preview}}</view>
        </view>
      </block>
      <view wx:if="{{annList.length === 0}}" class="home-ann-item card ha-empty">
        <view class="ha-title-row"><text class="ha-title">物业还没有发布公告</text></view>
        <view class="ha-preview">停水停电、消防演练等社区通知会第一时间出现在这里</view>
      </view>
    </view>
  </block>
</view>

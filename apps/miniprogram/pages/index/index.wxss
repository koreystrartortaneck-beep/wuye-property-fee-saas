.index-page {
  padding-bottom: 48rpx;
}

.top-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-orb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff8e9;
  font-size: 30rpx;
  font-weight: 900;
  background: linear-gradient(145deg, #f1d69a, #a87b38);
  box-shadow: 0 20rpx 42rpx rgba(155, 116, 58, 0.24);
}

.hero-card {
  position: relative;
  margin-top: 34rpx;
  padding: 46rpx 40rpx 38rpx;
  min-height: 440rpx;
  overflow: hidden;
  border-radius: 56rpx;
  color: #fff;
  /* 金色只做小面积高光；主体交给深紫渐变（避免金压紫变脏棕） */
  background:
    radial-gradient(circle at 88% 0%, rgba(232, 207, 160, 0.22), transparent 22%),
    radial-gradient(circle at 15% 100%, rgba(122, 96, 168, 0.25), transparent 45%),
    linear-gradient(150deg, #2b2145 0%, #251c38 55%, #3b2b57 100%);
  box-shadow: 0 34rpx 80rpx rgba(37, 28, 56, 0.24);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -100rpx;
  bottom: -146rpx;
  width: 410rpx;
  height: 410rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-kicker,
.panel-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  letter-spacing: 5rpx;
}

.hero-title {
  margin-top: 20rpx;
  white-space: pre-line;
  font-size: 64rpx;
  line-height: 1.14;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.house-chip {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 46rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.chip-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #d8bd7f;
  box-shadow: 0 0 0 10rpx rgba(216, 189, 127, 0.14);
}

.amount-panel {
  position: relative;
  z-index: 1;
  margin-top: 44rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.16);
}

.amount-row {
  margin-top: 14rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-amount {
  font-size: 58rpx;
  font-weight: 900;
}

.pay-btn {
  height: 78rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.quick-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.quick-card {
  min-height: 194rpx;
  padding: 26rpx 20rpx;
  border-radius: 38rpx;
  background: rgba(253, 251, 247, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 22rpx 48rpx rgba(70, 52, 29, 0.08);
}

.quick-active {
  background: linear-gradient(180deg, #fff9ed, #f1e1c5);
}

.quick-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9b743a;
  font-size: 28rpx;
  font-weight: 900;
  background: rgba(201, 166, 107, 0.18);
}

.quick-title {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.quick-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c7288;
}

.section-head {
  margin: 32rpx 4rpx 20rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-kicker,
.service-kicker {
  color: #9b743a;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.section-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.section-more {
  color: #9b743a;
  font-size: 26rpx;
  font-weight: 800;
}

.bill-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bill-card {
  padding: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bill-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.bill-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

.sapphire { background: linear-gradient(145deg, #4a3870, #251c38); }
.emerald { background: linear-gradient(145deg, #6f9795, #315f63); }
.amber { background: linear-gradient(145deg, #ddbd76, #9b743a); }

.bill-title {
  font-size: 28rpx;
  font-weight: 800;
}

.bill-desc {
  margin-top: 8rpx;
  color: #7c7288;
  font-size: 23rpx;
}

.bill-amount {
  font-size: 30rpx;
  font-weight: 900;
}

.service-card {
  margin-top: 28rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fbf0db, #fdfbf7 72%);
}

.service-title {
  margin-top: 10rpx;
  font-size: 29rpx;
  font-weight: 900;
}

.service-desc {
  margin-top: 8rpx;
  color: #7c7288;
  font-size: 23rpx;
}

.mini-dark {
  height: 68rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  color: #fdfbf7;
  font-size: 25rpx;
  font-weight: 800;
  background: #251c38;
}

/* 最新公告条（二期新增） */
.ann-bar {
  margin-top: 26rpx;
  padding: 22rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.ann-bar-icon {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #251c38;
  background: linear-gradient(145deg, #fff1c8, #c9a66b);
}

.ann-bar-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #251c38;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ann-bar-arrow {
  flex-shrink: 0;
  color: rgba(130, 120, 140, 0.55);
  font-size: 32rpx;
}

/* ===== 社区动态（首页改版：替代原账单列表区） ===== */
.home-ann-list {
  margin-top: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.home-ann-item {
  padding: 28rpx 30rpx;
}

.ha-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ha-pin {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: #9b743a;
  background: rgba(201, 166, 107, 0.16);
}

.ha-title {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  font-weight: 800;
  color: #251c38;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ha-date {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #a79eb5;
}

.ha-preview {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7c7288;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.ha-empty {
  opacity: 0.85;
}

/* ===== 快捷卡内容居中（用户反馈） ===== */
.quick-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.quick-icon {
  margin: 0 auto;
}

/* ===== 缴清徽章（替代孤立的大勾） ===== */
.paid-badge {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 30rpx 16rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(232, 207, 160, 0.14);
  border: 1rpx solid rgba(232, 207, 160, 0.35);
  color: #e8cfa0;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.pb-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  color: #251c38;
  background: linear-gradient(145deg, #fff1c8, #c9a66b);
}

/* ===== 物业公示横滑照片墙（首页新增） ===== */
.work-strip {
  margin-top: 4rpx;
  white-space: nowrap;
}

.work-strip-inner {
  display: inline-flex;
  gap: 18rpx;
  padding: 4rpx 0 8rpx;
}

.work-photo {
  position: relative;
  width: 240rpx;
  height: 180rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(37, 28, 56, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(70, 52, 29, 0.08);
}

.work-photo-img {
  width: 100%;
  height: 100%;
}

.work-photo-tag {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(37, 28, 56, 0.6);
}

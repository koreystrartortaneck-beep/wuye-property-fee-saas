.page.community-page {
  padding-top: 24rpx;
}

.filter-bar {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 2rpx;
}

.filter-chip {
  display: inline-flex;
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #7c7288;
  background: rgba(255, 250, 242, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
}

.chip-on {
  color: #251c38;
  background: linear-gradient(145deg, #fff1c8, #ead0a0);
  border-color: rgba(201, 166, 107, 0.5);
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* 物业公示卡 */
.feed-work {
  display: flex;
  gap: 22rpx;
  padding: 24rpx;
  align-items: stretch;
}

.fw-cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: rgba(37, 28, 56, 0.06);
}

.fw-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.fw-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fw-tag {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(145deg, #6d5b93, #3b2b57);
}

.fw-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #251c38;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fw-preview {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #7c7288;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.fw-foot {
  margin-top: auto;
  padding-top: 10rpx;
  display: flex;
  justify-content: space-between;
  font-size: 21rpx;
  color: #a79eb5;
}

/* 公告卡 */
.ann-card {
  padding: 28rpx 30rpx;
}

.ac-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ac-pin {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  color: #9b743a;
  background: rgba(201, 166, 107, 0.16);
}

.ac-title {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  font-weight: 800;
  color: #251c38;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ac-preview {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7c7288;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.ac-date {
  margin-top: 12rpx;
  font-size: 21rpx;
  color: #a79eb5;
}

.feed-empty {
  padding: 60rpx 40rpx;
  text-align: center;
}

.fe-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #251c38;
}

.fe-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8b8199;
  line-height: 1.5;
}

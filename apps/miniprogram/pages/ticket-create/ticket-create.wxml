<view class="page create-page">
  <view class="type-tabs card">
    <view
      wx:for="{{typeTabs}}"
      wx:key="value"
      class="type-tab {{typeIndex === index ? 'type-on' : ''}}"
      data-index="{{index}}"
      bindtap="setType"
    >{{item.label}}</view>
  </view>

  <view class="form-card card">
    <view class="form-label">所在房屋</view>
    <picker range="{{houses}}" range-key="displayName" value="{{houseIndex}}" bindchange="onHouseChange">
      <view class="house-pick">
        {{houses.length ? houses[houseIndex].communityName + ' ' + houses[houseIndex].displayName : '请先绑定房屋'}} ›
      </view>
    </picker>

    <view class="form-label">问题描述</view>
    <textarea class="content-input" placeholder="{{placeholder}}" maxlength="1000"
              value="{{content}}" bindinput="onContent" />

    <view class="form-label">现场照片（选填，最多 3 张）</view>
    <view class="img-row">
      <view class="img-box" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="img-del" data-index="{{index}}" catchtap="removeImage">×</view>
      </view>
      <view wx:if="{{images.length < 3}}" class="img-add" bindtap="chooseImage">＋</view>
    </view>
  </view>

  <button class="dark-button submit-btn" bindtap="submit">提交</button>
</view>

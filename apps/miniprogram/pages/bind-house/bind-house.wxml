<view class="page bind-page">
  <privacy-popup />
  <view class="nav-title">绑定房屋</view>
  <view class="nav-subtitle">绑定后即可查询与缴纳物业费用</view>

  <view class="bind-card card">
    <view class="bind-card-title">手机号快速绑定</view>
    <view class="bind-card-desc">物业已登记您的手机号时，可自动匹配名下房产</view>
    <!-- real 模式：微信授权按钮；mock 模式：手动输入 -->
    <block wx:if="{{!mockAuth}}">
      <button class="dark-button match-btn-full" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone">
        微信授权手机号，自动匹配房产
      </button>
    </block>
    <view wx:else class="phone-row">
      <input class="phone-input" type="number" maxlength="11" placeholder="请输入手机号"
             value="{{phone}}" bindinput="onPhoneInput" />
      <button class="gold-button match-btn" bindtap="matchByPhone">匹配</button>
    </view>
  </view>

  <view class="bind-card card">
    <view class="bind-card-title">自助申请绑定</view>
    <view class="bind-card-desc">选择小区与房号，提交后由物业审核</view>
    <view class="phone-row">
      <input class="phone-input" placeholder="搜索小区名称" value="{{keyword}}" bindinput="onKeywordInput" />
      <button class="gold-button match-btn" bindtap="searchCommunities">搜索</button>
    </view>

    <view wx:if="{{communities.length > 0 && !selectedCommunity}}" class="option-list">
      <view class="option-item" wx:for="{{communities}}" wx:key="id"
            data-index="{{index}}" bindtap="pickCommunity">
        <view class="option-main">{{item.name}}</view>
        <view class="option-sub">{{item.tenantName}} {{item.address || ''}}</view>
      </view>
    </view>

    <block wx:if="{{selectedCommunity}}">
      <view class="picked-line">已选小区：{{selectedCommunity.name}}</view>
      <view class="option-list house-grid">
        <view class="house-option {{selectedHouse && selectedHouse.id === item.id ? 'house-option-active' : ''}}"
              wx:for="{{houses}}" wx:key="id" data-index="{{index}}" bindtap="pickHouse">
          {{item.displayName}}
        </view>
      </view>

      <block wx:if="{{selectedHouse}}">
        <view class="form-row">
          <view class="form-label">您的姓名</view>
          <input class="form-input" placeholder="与物业登记一致" value="{{applicantName}}" bindinput="onNameInput" />
        </view>
        <view class="form-row">
          <view class="form-label">与房屋关系</view>
          <picker range="{{relations}}" range-key="label" value="{{relationIndex}}" bindchange="onRelationChange">
            <view class="form-input picker-value">{{relations[relationIndex].label}} ›</view>
          </picker>
        </view>
        <button class="dark-button apply-btn" bindtap="submitApply">提交绑定申请</button>
      </block>
    </block>
  </view>
</view>

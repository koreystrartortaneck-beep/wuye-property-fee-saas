.page.receipt-page {
  padding-top: 40rpx;
}

.rc-card {
  position: relative;
  padding: 48rpx 40rpx;
  overflow: hidden;
}

.rc-head {
  text-align: center;
}

.rc-org {
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 10rpx;
  color: #251c38;
}

.rc-sub {
  margin-top: 6rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #a79eb5;
}

.rc-amount-block {
  margin-top: 36rpx;
  text-align: center;
}

.rc-amount-label {
  font-size: 22rpx;
  color: #8b8199;
}

.rc-amount {
  margin-top: 10rpx;
  font-size: 64rpx;
  font-weight: 900;
  color: #251c38;
}

.rc-divider {
  height: 0;
  border-top: 2rpx dashed rgba(37, 28, 56, 0.14);
  margin: 30rpx 0;
}

.rc-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.rc-item {
  color: #8b8199;
}

.rc-val {
  color: #251c38;
  font-weight: 600;
  max-width: 420rpx;
  text-align: right;
}

/* 收讫章 */
.rc-stamp {
  position: absolute;
  right: 36rpx;
  bottom: 110rpx;
  width: 150rpx;
  height: 150rpx;
  border: 5rpx solid rgba(196, 86, 86, 0.75);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 900;
  color: rgba(196, 86, 86, 0.8);
  transform: rotate(-18deg);
  letter-spacing: 4rpx;
}

.rc-tip {
  margin-top: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: #a79eb5;
}

.rc-save {
  margin: 40rpx 40rpx 0;
}

/* 加载/错误态 */
.rc-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.rc-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid rgba(37, 28, 56, 0.12);
  border-top-color: #b08d57;
  border-radius: 50%;
  animation: rc-spin 0.8s linear infinite;
}

@keyframes rc-spin {
  to { transform: rotate(360deg); }
}

.rc-state-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #a79eb5;
}

.rc-retry {
  margin-top: 28rpx;
  padding: 0 48rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 26rpx;
  color: #251c38;
  background: rgba(176, 141, 87, 0.14);
  border-radius: 40rpx;
}

/* 离屏画布：不可见但需真实渲染 */
.rc-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 620px;
  height: 1200px;
}

.mine-page {
  padding-bottom: 48rpx;
}

.profile-card {
  margin-top: 28rpx;
  padding: 44rpx 36rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  color: #fff;
  background: radial-gradient(circle at 88% 0%, rgba(201, 166, 107, 0.76), transparent 30%), linear-gradient(145deg, #2a2144, #443465 66%, #7b6f95);
  box-shadow: 0 34rpx 80rpx rgba(42, 33, 68, 0.24);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2a2144;
  font-size: 40rpx;
  font-weight: 900;
  background: linear-gradient(145deg, #fff1c8, #c9a66b);
}

.profile-name {
  font-size: 40rpx;
  font-weight: 900;
}

.profile-phone {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.section-title {
  margin: 36rpx 4rpx 20rpx;
  font-size: 38rpx;
  font-weight: 900;
}

/* ---- 方案3：当前房屋单卡 + 弹出切换 ---- */
.current-house {
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.ch-left {
  min-width: 0;
  flex: 1;
}

.house-community {
  font-size: 22rpx;
  color: #8a7f73;
}

.ch-title-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.ch-name {
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.house-tag {
  flex-shrink: 0;
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #9b743a;
  font-size: 21rpx;
  font-weight: 800;
  background: rgba(201, 166, 107, 0.16);
}

.ch-right {
  flex-shrink: 0;
  text-align: right;
}

.ch-count {
  font-size: 21rpx;
  color: #a89d8f;
}

.ch-switch {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #9b743a;
}

/* 申请进度细行 */
.pending-lines {
  margin-top: 16rpx;
  padding: 0 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pending-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pending-dot {
  flex-shrink: 0;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #d9a94e;
}

.dot-rejected {
  background: #c45656;
}

.pending-text {
  font-size: 23rpx;
  color: #8a7f73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-title {
  margin-top: 42rpx;
}

.menu-card {
  padding: 8rpx 30rpx;
}

.menu-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(42, 33, 68, 0.06);
}

.menu-row:first-child {
  border-top: 0;
}

.menu-name {
  font-size: 29rpx;
  font-weight: 900;
}

.menu-desc {
  margin-top: 8rpx;
  color: #82786c;
  font-size: 24rpx;
}

.arrow {
  color: #c9a66b;
  font-size: 48rpx;
  line-height: 1;
}

/* 申请进度（打磨新增） */
.pending-card {
  opacity: 0.92;
}

.tag-pending {
  color: #b8862f;
}

.tag-rejected {
  color: #c45656;
}

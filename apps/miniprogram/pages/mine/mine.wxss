.mine-page {
  padding-bottom: 48rpx;
}

.profile-card {
  margin-top: 4rpx;
  padding: 44rpx 36rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  color: #fff;
  background: radial-gradient(circle at 88% 0%, rgba(201, 166, 107, 0.76), transparent 30%), linear-gradient(145deg, #102033, #263f5a 66%, #5f7f86);
  box-shadow: 0 34rpx 80rpx rgba(16, 32, 51, 0.24);
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #102033;
  font-size: 40rpx;
  font-weight: 900;
  background: linear-gradient(145deg, #fff1c8, #c9a66b);
}

.profile-name {
  font-size: 40rpx;
  font-weight: 900;
}

.profile-phone {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.section-title {
  margin: 36rpx 4rpx 20rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.section-head-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 36rpx 4rpx 20rpx;
}

.section-head-row .section-title {
  margin: 0;
}

.section-hint {
  font-size: 22rpx;
  color: #a89d8f;
}

/* 横滑房屋卡片 */
.house-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;          /* 让卡片滑出页面边距，更通透 */
  padding: 0 32rpx;
  box-sizing: content-box;
}

.house-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 6rpx 32rpx 16rpx 0;
}

.house-card2 {
  position: relative;
  width: 300rpx;
  flex-shrink: 0;
  padding: 28rpx 26rpx;
  white-space: normal;
}

.house-on {
  background: linear-gradient(135deg, #fbf0db, #fffaf2 72%);
  border: 2rpx solid rgba(201, 166, 107, 0.55);
}

.house-community {
  font-size: 22rpx;
  color: #8a7f73;
}

.house-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
  min-height: 76rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.house-tag {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #9b743a;
  font-size: 21rpx;
  font-weight: 800;
  background: rgba(201, 166, 107, 0.16);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.house-check2 {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  background: #9b743a;
}

.house-pending {
  opacity: 0.9;
}

/* 绑定新房产入口卡 */
.house-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(155, 116, 58, 0.4);
  background: rgba(255, 250, 242, 0.5);
  box-shadow: none;
}

.add-plus {
  font-size: 52rpx;
  color: #c9a66b;
  line-height: 1;
}

.add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9b743a;
  font-weight: 700;
}

.menu-title {
  margin-top: 42rpx;
}

.menu-card {
  padding: 8rpx 30rpx;
}

.menu-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(16, 32, 51, 0.06);
}

.menu-row:first-child {
  border-top: 0;
}

.menu-name {
  font-size: 29rpx;
  font-weight: 900;
}

.menu-desc {
  margin-top: 8rpx;
  color: #82786c;
  font-size: 24rpx;
}

.arrow {
  color: #c9a66b;
  font-size: 48rpx;
  line-height: 1;
}

/* 申请进度（打磨新增） */
.pending-card {
  opacity: 0.92;
}

.tag-pending {
  color: #b8862f;
}

.tag-rejected {
  color: #c45656;
}

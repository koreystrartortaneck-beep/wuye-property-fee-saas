.pay-list {
  margin-top: 36rpx;
}

.pay-item {
  padding: 32rpx 36rpx;
  margin-bottom: 26rpx;
}

.pay-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pay-item-amount {
  font-size: 40rpx;
  font-weight: 800;
}

.pay-item-status {
  font-size: 22rpx;
  color: #8b8199;
}

.pay-item-status.ok {
  color: #3f7d5d;
  font-weight: 700;
}

.pay-item-bills {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #55496b;
}

.pay-item-meta {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #9a9288;
}

/* 原生导航栏下收紧顶部留白 */
.page.payments-page {
  padding-top: 32rpx;
}

.nav-link {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9b743a;
}

.pay-item-status.refunded {
  color: #b46a6a;
}

.pay-item-invoice {
  margin-top: 16rpx;
  text-align: right;
  font-size: 24rpx;
  color: #9b743a;
}
